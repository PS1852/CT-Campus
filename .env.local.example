# CT Campus - Environment Variables Template
# Copy this file to .env.local and populate the values.

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://ihidmclkugsmoygegipp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google OAuth Credentials (for Supabase OAuth flow)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth Configurations (for Session Management if needed, or secure tokens)
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# Razorpay Payments (Placeholder Architecture)
NEXT_PUBLIC_RAZORPAY_KEY_ID=placeholder_key_id
RAZORPAY_KEY_SECRET=placeholder_key_secret

# Coaching Helpline & Support Details
NEXT_PUBLIC_COACHING_EMAIL=ctcampus2019@gmail.com
NEXT_PUBLIC_SUPPORT_PHONE=8800833665
